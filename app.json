{
  "expo": {
    "name": "RISE Reports",
    "slug": "rise-reports",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/1-7ffa7b50.png",
    "scheme": "rise-reports",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rise.reports",
      "buildNumber": "12",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/1-7ffa7b50.png",
        "backgroundImage": "./assets/images/1-7ffa7b50.png",
        "monochromeImage": "./assets/images/1-7ffa7b50.png"
      },
      "package": "com.rise.reports",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/1-7ffa7b50.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/1-7ffa7b50.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b2f2903-5994-4318-bc2d-0e470ffe78c3"
      }
    }
  }
}
